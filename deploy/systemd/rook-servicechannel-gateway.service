[Unit]
Description=RooK Servicechannel Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rook-gateway
Group=rook-gateway
EnvironmentFile=/etc/rook-servicechannel-gateway/gateway.env
ExecStart=/usr/bin/rook-servicechannel-gateway
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
PrivateDevices=true

[Install]
WantedBy=multi-user.target
