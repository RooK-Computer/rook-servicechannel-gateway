GATEWAY_LISTEN_ADDRESS=127.0.0.1:8080
GATEWAY_HTTP_READ_HEADER_TIMEOUT=5s
GATEWAY_BACKEND_BASE_URL=https://backend.example.test
GATEWAY_BACKEND_TIMEOUT=5s
GATEWAY_LOG_LEVEL=info
GATEWAY_SSH_PRIVATE_KEY_PATH=/run/secrets/rook-servicechannel-gateway/id_ed25519
GATEWAY_SSH_PUBLIC_KEY_PATH=/run/secrets/rook-servicechannel-gateway/id_ed25519.pub
GATEWAY_SSH_USERNAME=pi
GATEWAY_SSH_PORT=22
GATEWAY_SSH_CONNECT_TIMEOUT=5s
GATEWAY_SSH_INSECURE_IGNORE_HOST_KEY=true
GATEWAY_SESSION_IDLE_TIMEOUT=2m
GATEWAY_SESSION_MAX_CONCURRENT=32
GATEWAY_SESSION_OUTBOUND_QUEUE_DEPTH=16
GATEWAY_WEBSOCKET_MAX_MESSAGE_BYTES=65536
